<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="app.ShowcasePage">
    <Grid>

        <CarouselView x:Name="carouselView"
                      ItemsSource="{Binding ImagePaths}"
                      PositionChanged="OnPositionChanged">
            <CarouselView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Image x:Name="img"
                               Source="{Binding}" 
                               Aspect="AspectFit" />
                        <ActivityIndicator 
                            IsRunning="{Binding Source={x:Reference img}, Path=IsLoading}"
                            IsVisible="{Binding Source={x:Reference img}, Path=IsLoading}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <Grid Padding="20"
              RowDefinitions="1*, 5*, 1*"
              ColumnDefinitions="1*, 5*, 1*">

            <Label x:Name="Info"
                   Text="This is some really interesting Information"
                   Grid.Row="0"
                   Grid.Column="2"
                   Grid.ColumnSpan="3"
                   HorizontalOptions="End"
                   VerticalOptions="Start"
                   TextColor="White"
                   BackgroundColor="Gray"
                   FontSize="20"/>

            <Button Text="&lt;"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource directionButton}"
                    Clicked="OnPrevClicked"/>

            <Button Text=">"
                    Grid.Row="1"
                    Grid.Column="2"
                    Style="{StaticResource directionButton}"
                    Clicked="OnNextClicked"/>

            <WebView x:Name="webView"
                     Grid.Row="2"
                     Grid.Column="2"
                     HorizontalOptions="End"
                     VerticalOptions="End"
                     HeightRequest="200"
                     WidthRequest="200">
                <WebView.Source>
                    <UrlWebViewSource Url="map.html"/>
                </WebView.Source>
            </WebView>

        </Grid>

        <Grid
            BackgroundColor="#80000000"
            IsVisible="{Binding IsLoading}">

            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="12"
                WidthRequest="300">

                <ProgressBar
                    Progress="{Binding Progress}"
                    HeightRequest="8" />

                <Label
                    Text="{Binding Progress, StringFormat='{0:P0}'}"
                    HorizontalOptions="Center"
                    TextColor="White" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>