<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:app"
             x:Class="app.CollectionPage">
    <Grid>

        <!-- SINGLE IMAGE VIEW -->
        <local:ZoomView
            x:Name="SingleView"
            IsVisible="True"
            Scale="1">
            <Image
                Source="{Binding ImagePath}"
                Aspect="AspectFit" >
                <Image.GestureRecognizers>
                    <PanGestureRecognizer 
                        PanUpdated="OnPanUpdated"/>
                    <PointerGestureRecognizer 
                        PointerEntered="OnPointerEntered"
                        PointerExited="OnPointerExited"/>
                </Image.GestureRecognizers>
            </Image>
        </local:ZoomView>

        <!-- MULTI IMAGE VIEW -->
        <CollectionView
            x:Name="MultiView"
            IsVisible="False"
            Scale="0.85"
            ItemsSource="{Binding GroupImagePaths}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout x:Name="GIL"  Orientation="Vertical" Span="3" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Image
                    Source="{Binding .}"
                    Aspect="AspectFill"
                    Margin="1"
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="FillAndExpand" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- UI -->
        <Grid
            RowDefinitions="1*, *, 1*"
            ColumnDefinitions="1*, *, 1*"
            InputTransparent="True"
            CascadeInputTransparent="False"
            Padding="20">

            <!-- Zoom In/Out Button -->
            <Grid
                Grid.Row="0"
                Grid.Column="0"
                RowDefinitions="Auto, Auto"
                ColumnDefinitions="Auto, Auto"
                Padding="10"
                VerticalOptions="Start">

                <Button Text="↑"
                        Grid.Row="0"
                        Grid.Column="0"
                        x:Name="GoBiggerButton"
                        Style="{StaticResource directionButton}"
                        Clicked="BiggerGroupClicked"/>
                <Button Text="↓"
                        Grid.Row="0"
                        Grid.Column="1"
                        x:Name="GoSmallerButton"
                        Style="{StaticResource directionButton}"
                        Clicked="SmallerGroupClicked"/>


                <Button Text="+"
                        Grid.Row="1"
                        Grid.Column="0"
                        x:Name="ZoomIn"
                        Style="{StaticResource directionButton}"
                        Clicked="OnZoomInClicked"/>
                <Button Text="-"
                        Grid.Row="1"
                        Grid.Column="1"
                        x:Name="ZoomOut"
                        Style="{StaticResource directionButton}"
                        Clicked="OnZoomOutClicked"/>
            </Grid>

            <!-- Info Box-->
            <Label x:Name="Info"
                   Grid.Row="0"
                   Grid.Column="2"
                   Text="Information"
                   HorizontalOptions ="End"
                   VerticalOptions ="Start"
                   Style="{StaticResource infoLabel}"/>

            <!-- Move Left/Right Buttons -->
            <Button 
                Grid.Row="1"
                Grid.Column="0"
                Text="&lt;"
                VerticalOptions="Center"
                HorizontalOptions="Start"
                Style="{StaticResource directionButton}"
                Clicked="OnPrevClicked"/>

            <Button 
                Grid.Row="1"
                Grid.Column="2"
                Text="&gt;"
                VerticalOptions="Center"
                HorizontalOptions="End"
                Style="{StaticResource directionButton}"
                Clicked="OnNextClicked"/>

            <!-- Map -->
            <WebView 
                Grid.Row="2"
                Grid.Column="2"
                x:Name="webView"
                HorizontalOptions="End"
                VerticalOptions="End"
                HeightRequest="200"
                WidthRequest="200">
                <WebView.Source>
                    <UrlWebViewSource Url="map.html"/>
                </WebView.Source>
            </WebView>
        </Grid>

        <!-- Loading Overlay -->
        <Grid
            BackgroundColor="#80000000"
            IsVisible="{Binding IsLoading}">

            <VerticalStackLayout
                    HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="12"
            WidthRequest="300">

                <ProgressBar
            Progress="{Binding Progress}"
            HeightRequest="8" />

                <Label
                Text="{Binding Progress, StringFormat='{0:P0}'}"
                HorizontalOptions="Center"
                TextColor="White" />
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>