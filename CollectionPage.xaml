<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:app"
             xmlns:converters="clr-namespace:app.Converters"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="app.CollectionPage"
             x:Name="pageRef">
    <ContentPage.Resources>
        <converters:ThumbnailPathConverter x:Key="ThumbnailPathConverter"/>
        <converters:MultiplyConverter x:Key="MultiplyConverter"/>
    </ContentPage.Resources>
    <Grid>

        <!-- SINGLE IMAGE VIEW -->
        <local:ZoomView
            x:Name="SingleView"
            IsVisible="True"
            Scale="1">
            <Image
                Source="{Binding ImagePath}"
                Aspect="AspectFit">
                <Image.GestureRecognizers>
                    <PanGestureRecognizer 
                        PanUpdated="OnPanUpdated"/>
                    <PointerGestureRecognizer 
                        PointerEntered="OnPointerEntered"
                        PointerExited="OnPointerExited"/>
                </Image.GestureRecognizers>
            </Image>
        </local:ZoomView>

        <!-- <ScrollView
            ContentOrientation="None"
            ZoomMode="Enabled">
            <Image Source="{Binding ImagePath}"/>
        </ScrollView> -->

        <!-- MULTI IMAGE VIEW -->
        <ScrollView
            x:Name="MultiView"
            IsVisible="False">
            <FlexLayout
                Wrap="Wrap"
                Direction="Row"
                JustifyContent="Center"
                BindableLayout.ItemsSource="{Binding GroupImageItems}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            Margin="1"
                            WidthRequest="{Binding CellSize, Source={x:Reference pageRef}}"
                            HeightRequest="{Binding CellSize, Source={x:Reference pageRef}}">
                            <Image
                                Source="{Binding Path, Converter={StaticResource ThumbnailPathConverter}}"
                                Aspect="AspectFill">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer
                                        NumberOfTapsRequired="1"
                                        Tapped="OnImageSingleTapped"
                                        CommandParameter="{Binding Path}"/>
                                    <TapGestureRecognizer
                                        NumberOfTapsRequired="2"
                                        Tapped="OnImageDoubleTapped"
                                        CommandParameter="{Binding Path}"/>
                                </Image.GestureRecognizers>
                            </Image>
                            <Label
                                Text="♥"
                                IsVisible="{Binding IsLiked}"
                                TextColor="White"
                                FontSize="{Binding CellSize, Source={x:Reference pageRef}, Converter={StaticResource MultiplyConverter}, ConverterParameter='0.25'}"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="4,0,0,4"
                                InputTransparent="True">
                                <Label.Shadow>
                                    <Shadow Brush="Black" Offset="1,1" Radius="2" Opacity="0.8"/>
                                </Label.Shadow>
                            </Label>
                            <shapes:Rectangle
                                IsVisible="{Binding IsSelected}"
                                Fill="Transparent"
                                Stroke="CornflowerBlue"
                                StrokeThickness="4"
                                InputTransparent="True"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"/>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </ScrollView>

        <!-- UI -->
        <Grid
            RowDefinitions="1*, *, 1*"
            ColumnDefinitions="1*, *, 1*"
            InputTransparent="True"
            CascadeInputTransparent="False"
            Padding="20">

            <!-- Zoom In/Out Button -->
            <Grid
                Grid.Row="0"
                Grid.Column="0"
                RowDefinitions="Auto, Auto"
                ColumnDefinitions="Auto, Auto"
                Padding="10"
                VerticalOptions="Start">

                <Button Text="↑"
                        Grid.Row="0"
                        Grid.Column="0"
                        x:Name="GoBiggerButton"
                        Style="{StaticResource directionButton}"
                        Clicked="BiggerGroupClicked"/>
                <Button Text="↓"
                        Grid.Row="0"
                        Grid.Column="1"
                        x:Name="GoSmallerButton"
                        Style="{StaticResource directionButton}"
                        Clicked="SmallerGroupClicked"/>

                <Button Text="{Binding LikeButtonText}"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource directionButton}"
                        Clicked="OnLikeClicked"/>
            </Grid>

            <!-- Info Box-->
            <Label x:Name="Info"
                   Grid.Row="0"
                   Grid.Column="2"
                   Text="Information"
                   HorizontalOptions ="End"
                   VerticalOptions ="Start"
                   Style="{StaticResource infoLabel}"/>

            <!-- Move Left/Right Buttons -->
            <Button 
                Grid.Row="1"
                Grid.Column="0"
                Text="&lt;"
                VerticalOptions="Center"
                HorizontalOptions="Start"
                Style="{StaticResource directionButton}"
                Clicked="OnPrevClicked"/>

            <Button 
                Grid.Row="1"
                Grid.Column="2"
                Text="&gt;"
                VerticalOptions="Center"
                HorizontalOptions="End"
                Style="{StaticResource directionButton}"
                Clicked="OnNextClicked"/>

            <!-- Map -->
            <WebView
                Grid.Row="2"
                Grid.Column="2"
                x:Name="webView"
                HorizontalOptions="End"
                VerticalOptions="End"
                HeightRequest="200"
                WidthRequest="200"
                Navigated="OnMapNavigated">
                <WebView.Source>
                    <UrlWebViewSource Url="map.html"/>
                </WebView.Source>
            </WebView>
        </Grid>

        <!-- Loading Overlay -->
        <Grid
            BackgroundColor="#80000000"
            IsVisible="{Binding IsLoading}">

            <VerticalStackLayout
                    HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="12"
            WidthRequest="300">

                <ProgressBar
            Progress="{Binding Progress}"
            HeightRequest="8" />

                <Label
                Text="{Binding Progress, StringFormat='{0:P0}'}"
                HorizontalOptions="Center"
                TextColor="White" />
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>