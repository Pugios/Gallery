<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="app.Tester">
    <Grid RowDefinitions="*">
        <!-- SINGLE IMAGE VIEW -->
        <ContentView
            x:Name="SingleView"
            Opacity="1"
            Scale="1">

            <Image
                Source="{Binding ImagePath}"
                Aspect="AspectFit" />
        </ContentView>

        <!-- MULTI IMAGE VIEW -->
        <CollectionView
            x:Name="MultiView"
            Opacity="0"
            Scale="0.85"
            ItemsSource="{Binding GroupImagePaths}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Image
                        Source="{Binding .}"
                        Aspect="AspectFill"
                        Margin="1"
                        HorizontalOptions="FillAndExpand"
                        VerticalOptions="FillAndExpand" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- UI -->
        <Grid Padding="20"
          RowDefinitions="1*, 5*, 1*"
          ColumnDefinitions="1*, 5*, 1*"
                  InputTransparent="True">

            <StackLayout
        Grid.Row="0"
        Grid.Column="0"
        Orientation="Horizontal"
        HorizontalOptions="Start"
        VerticalOptions="Start"
        InputTransparent="False"
        Spacing="10">

                <Button Text="+"
                        InputTransparent="False"
                x:Name="ZoomInButton"
                Style="{StaticResource directionButton}"
                Clicked="OnZoomInClicked"/>
                <Button Text="-"
                        InputTransparent="False"
                x:Name="ZoomOutButton"
                Style="{StaticResource directionButton}"
                Clicked="OnZoomOutClicked"/>

            </StackLayout>

            <Label x:Name="Info"
           Text="Tester Information"
           Grid.Row="0"
           Grid.Column="2"
           Grid.ColumnSpan="3"
           HorizontalOptions="End"
           VerticalOptions="Start"
           TextColor="White"
           BackgroundColor="Gray"
           FontSize="20"/>

            <Button Text="&lt;"
            InputTransparent="False"
            Grid.Row="1"
            Grid.Column="0"
            Style="{StaticResource directionButton}"
            Clicked="OnPrevClicked"/>

            <Button Text=">"
        InputTransparent="False"
        Grid.Row="1"
        Grid.Column="2"
        Style="{StaticResource directionButton}"
        Clicked="OnNextClicked"/>

            <WebView x:Name="webView"
             InputTransparent="False"
             Grid.Row="2"
             Grid.Column="2"
             HorizontalOptions="End"
             VerticalOptions="End"
             HeightRequest="200"
             WidthRequest="200">
                <WebView.Source>
                    <UrlWebViewSource Url="map.html"/>
                </WebView.Source>
            </WebView>
        </Grid> -->
    </Grid>
</ContentPage>