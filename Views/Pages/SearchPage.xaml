<Page
    x:Class="Gallery2.Views.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Gallery2.Views.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ScrollViewer.CanContentScroll="False"
    Title="SearchPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Face button — shared by both the full-page grid and the compact strip -->
        <DataTemplate x:Key="FaceItemTemplate">
            <Button
                Width="100"
                Margin="8,6"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding DataContext.ViewModel.SelectPersonCommand,
                          RelativeSource={RelativeSource AncestorType=Page}}"
                CommandParameter="{Binding}">
                <StackPanel>
                    <Grid
                        Width="72"
                        Height="72"
                        HorizontalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Fill>
                                <ImageBrush
                                    ImageSource="{Binding Thumbnail}"
                                    Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse
                            x:Name="SelectionRing"
                            Stroke="Black"
                            StrokeThickness="2" />
                    </Grid>
                    <TextBlock
                        Text="{Binding Name}"
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Margin="0,4,0,0"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="SelectionRing" Property="Stroke"
                            Value="{DynamicResource AccentFillColorDefaultBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Progress Bar -->
        <StackPanel
            Grid.Row="0"
            Width="340"
            Orientation="Vertical"
            HorizontalAlignment="Center"
            Margin="0,0,0,16"
            Visibility="{Binding ViewModel.IsIndexing, Converter={StaticResource BoolToVis}}">
            <ui:TextBlock
                Text="{Binding ViewModel.StepText}"
                FontWeight="SemiBold"
                Margin="0,0,0,6" />
            <ProgressBar
                Value="{Binding ViewModel.Progress}"
                Maximum="100"
                Height="8" />
        </StackPanel>

        <!-- ═══ FULL-PAGE GRID — no person selected ══════════════════════════ -->
        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Visibility="{Binding ViewModel.IsPersonNotSelected, Converter={StaticResource BoolToVis}}">
            <ItemsControl
                ItemsSource="{Binding ViewModel.People}"
                ItemTemplate="{StaticResource FaceItemTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══ STRIP + GALLERY — person selected ════════════════════════════ -->
        <Grid
            Grid.Row="1"
            Visibility="{Binding ViewModel.IsPersonSelected, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Compact horizontal strip -->
            <ScrollViewer
                x:Name="PeopleStripScroll"
                Grid.Row="0"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled"
                PreviewMouseWheel="PeopleStripScroll_PreviewMouseWheel">
                <ItemsControl
                    x:Name="PeopleStrip"
                    ItemsSource="{Binding ViewModel.People}"
                    ItemTemplate="{StaticResource FaceItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- Filtered pictures grid -->
            <ui:VirtualizingGridView
                x:Name="ImageGrid"
                Grid.Row="1"
                ItemsSource="{Binding ViewModel.Pictures}"
                SpacingMode="Uniform"
                VirtualizingPanel.ScrollUnit="Pixel"
                MouseDoubleClick="ImageGrid_MouseDoubleClick"
                PreviewMouseWheel="ImageGrid_PreviewMouseWheel">
                <ui:VirtualizingGridView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="180"
                            Height="180"
                            CornerRadius="4"
                            ClipToBounds="True">
                            <Image
                                Source="{Binding Thumbnail}"
                                Stretch="UniformToFill" />
                        </Border>
                    </DataTemplate>
                </ui:VirtualizingGridView.ItemTemplate>
            </ui:VirtualizingGridView>
        </Grid>
    </Grid>
</Page>
