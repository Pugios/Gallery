<Page
    x:Name="page"
    x:Class="Gallery2.Views.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Gallery2.Views.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False"
    Title="SearchPage">

    <Page.Resources>
        <BooleanToVisibilityConverter
            x:Key="BoolToVis" />
    </Page.Resources>

    <DockPanel
        Margin="0,16,0,0">
        <StackPanel
            DockPanel.Dock="Top">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition
                        Height="Auto" />
                    <RowDefinition
                        Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Start Indexing button -->
                <ui:Button
                    Grid.Row="0"
                    Content="Start Indexing"
                    Icon="{ui:SymbolIcon Play24}"
                    Command="{Binding ViewModel.StartIndexingCommand}"
                    Visibility="{Binding ViewModel.IsNotIndexing, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16" />

                <!-- Progress Bar -->
                <StackPanel
                    Grid.Row="0"
                    Width="340"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16"
                    Visibility="{Binding ViewModel.IsIndexing, Converter={StaticResource BoolToVis}}">
                    <ui:TextBlock
                        Text="{Binding ViewModel.StepText}"
                        FontWeight="SemiBold"
                        Margin="0,0,0,6" />
                    <ProgressBar
                        Value="{Binding ViewModel.Progress}"
                        Maximum="100"
                        Height="8" />
                </StackPanel>

                <!-- People face selector -->
                <ScrollViewer
                    Grid.Row="1"
                    MaxHeight="200"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl
                        ItemsSource="{Binding ViewModel.People}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Width="100"
                                    Margin="8,4"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.ViewModel.SelectPersonCommand,
                        RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}">
                                    <StackPanel>
                                        <Border
                                            Width="72"
                                            Height="72"
                                            CornerRadius="90"
                                            ClipToBounds="True"
                                            HorizontalAlignment="Center"
                                            BorderThickness="2"
                                            BorderBrush="{DynamicResource AccentFillColorDefaultBrush}">
                                            <Image
                                                Source="{Binding Thumbnail}"
                                                Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock
                                            Text="{Binding Name}"
                                            HorizontalAlignment="Center"
                                            FontSize="11"
                                            Margin="0,4,0,0"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </StackPanel>

        <!-- Filtered pictures grid -->
        <ui:VirtualizingGridView
            ItemsSource="{Binding ViewModel.Pictures}"
            SpacingMode="Uniform">

            <ui:VirtualizingGridView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Width="180"
                        Height="180"
                        CornerRadius="4"
                        ClipToBounds="True">
                        <Image
                            Source="{Binding Thumbnail}"
                            Stretch="UniformToFill" />
                    </Border>
                </DataTemplate>
            </ui:VirtualizingGridView.ItemTemplate>
        </ui:VirtualizingGridView>
    </DockPanel>
</Page>
