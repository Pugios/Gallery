<Page
    x:Class="Gallery2.Views.Pages.GalleryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Gallery2.Views.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Title="GalleryPage">
    
    <Page.Resources>
        <BooleanToVisibilityConverter
            x:Key="BoolToVis" />
    </Page.Resources>

    <Grid>
        <!-- Empty state: shown when no folder has been loaded yet -->
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding ViewModel.ShowEmptyState, Converter={StaticResource BoolToVis}}">
            <ui:SymbolIcon
                HorizontalAlignment="Center"
                FontSize="52"
                Opacity="0.3"
                Symbol="FolderOpen24" />
            <TextBlock
                Margin="0,16,0,4"
                HorizontalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"
                Text="No folder selected" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="13"
                Opacity="0.6"
                Text="Choose a folder to start browsing your pictures" />
            <ui:Button
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Appearance="Primary"
                Command="{Binding ViewModel.AddFolderCommand}"
                Content="Select Folder"
                Icon="{ui:SymbolIcon FolderAdd24}" />
        </StackPanel>

        <!-- Loading bar -->
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVis}}">
            <ProgressBar
                Width="220"
                Maximum="100"
                Value="{Binding ViewModel.LoadingProgress, Mode=OneWay}" />
            <TextBlock
                Margin="0,8,0,0"
                HorizontalAlignment="Center"
                FontSize="12"
                Opacity="0.6"
                Text="{Binding ViewModel.LoadingProgress, StringFormat={}{0:F0}%}" />
        </StackPanel>

        <!-- Image grid: appears as soon as the first items are added -->
        <ui:VirtualizingGridView
            ItemsSource="{Binding ViewModel.Pictures}"
            SpacingMode="Uniform"
            Visibility="{Binding ViewModel.HasPictures, Converter={StaticResource BoolToVis}}">

            <ui:VirtualizingGridView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Width="180"
                        Height="180"
                        CornerRadius="4"
                        ClipToBounds="True">
                        <Image
                            Source="{Binding Thumbnail}"
                            Stretch="UniformToFill" />
                    </Border>
                </DataTemplate>
            </ui:VirtualizingGridView.ItemTemplate>

            <ui:VirtualizingGridView.ItemContainerStyle>
                <Style
                    TargetType="ListViewItem">
                    <Setter
                        Property="Focusable"
                        Value="False" />
                    <Setter
                        Property="Padding"
                        Value="4" />
                    <Setter
                        Property="Background"
                        Value="Transparent" />
                    <Setter
                        Property="BorderThickness"
                        Value="0" />
                </Style>
            </ui:VirtualizingGridView.ItemContainerStyle>

        </ui:VirtualizingGridView>

    </Grid>
</Page>
